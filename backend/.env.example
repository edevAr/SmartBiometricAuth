PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=smart_biometricauthenticator

JWT_SECRET=cambia-esto-en-produccion-minimo-32-caracteres

# Monitor de cámaras (intervalo en ms; 0 = desactivar monitor)
# CAMERA_MONITOR_ENABLED=0
# CAMERA_MONITOR_INTERVAL_MS=4000

# Detección de persona con COCO-SSD (solo clase «person» → alertas). 0 = sin ML (no habrá alertas de persona)
# CAMERA_PERSON_ML_ENABLED=1
# Umbral de confianza 0–1 (más alto = menos falsos positivos, más falsos negativos)
# CAMERA_PERSON_MIN_SCORE=0.32
# Redimensionar lado largo del JPEG antes de inferencia (más alto = mejor detección lejana, más CPU)
# CAMERA_PERSON_MAX_INPUT_SIDE=800
# Base COCO-SSD: mobilenet_v1 | mobilenet_v2 | lite_mobilenet_v2 (por defecto mobilenet_v2; lite = más rápido en CPU)
# CAMERA_PERSON_SSD_BASE=mobilenet_v2
# Log cuando hay detección "person" pero no supera el umbral: CAMERA_PERSON_DEBUG=1
# Mínimo tiempo entre alertas de la misma cámara (ms)
# CAMERA_PERSON_COOLDOWN_MS=75000

# Usuario admin inicial (seed al arrancar si no existe)
DEFAULT_ADMIN_EMAIL=admin@securehome.local
DEFAULT_ADMIN_PASSWORD=SmartBioAuth2025!
